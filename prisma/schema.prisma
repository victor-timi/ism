generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth / Auth.js v5) ────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  savedItems  SavedItem[]
  savedEvents SavedEvent[]
  alerts      Alert[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

enum ListingType {
  JOB
  HOUSING
  DISCOUNT
}

model Listing {
  id          String      @id @default(cuid())
  type        ListingType
  source      String // e.g. "ozbargain", "flatmates", "seek-partner"
  sourceId    String // ID from the original source
  title       String
  description String?     @db.Text
  url         String
  imageUrl    String?
  location    String?
  metadata    Json?       @db.JsonB // type-specific fields
  contentHash String? // SHA-256 for cross-source dedup
  isActive    Boolean     @default(true)
  publishedAt DateTime?
  scrapedAt   DateTime    @default(now())
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  savedBy SavedItem[]

  @@unique([source, sourceId])
  @@index([type, isActive, publishedAt(sort: Desc)])
  @@index([contentHash])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}

model Alert {
  id         String         @id @default(cuid())
  userId     String
  type       ListingType
  keywords   String[]
  location   String?
  frequency  AlertFrequency @default(DAILY)
  isActive   Boolean        @default(true)
  lastSentAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type, isActive])
}

model SavedEvent {
  id             String   @id @default(cuid())
  userId         String
  sanityEventId  String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sanityEventId])
  @@index([userId])
}

// ─── Ingestion Tracking ──────────────────────────────────────────────────────

enum IngestionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model IngestionRun {
  id           String          @id @default(cuid())
  source       String
  status       IngestionStatus
  found        Int             @default(0)
  created      Int             @default(0)
  updated      Int             @default(0)
  skipped      Int             @default(0)
  errorMessage String?         @db.Text
  duration     Int? // milliseconds
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
}
